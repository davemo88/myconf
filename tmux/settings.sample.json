{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "~/.config/tmux/agent-state.sh working" } ] }
    ],
    "PreToolUse": [
      { "hooks": [ { "type": "command", "command": "~/.config/tmux/agent-state.sh working" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "~/.config/tmux/agent-state.sh attention" } ] }
    ],
    "Notification": [
      { "hooks": [ { "type": "command", "command": "~/.config/tmux/agent-state.sh attention" } ] }
    ]
  }
}
